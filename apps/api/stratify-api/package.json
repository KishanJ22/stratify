{
    "name": "@stratify/stratify-api",
    "version": "0.2.7",
    "description": "",
    "type": "module",
    "main": "dist/app.js",
    "private": true,
    "files": [
        "dist",
        "docs"
    ],
    "scripts": {
        "prebuild": "pnpm generate-spec",
        "build": "tsc",
        "predev": "pnpm generate-spec",
        "dev": "tsx --watch src/app.ts",
        "prod": "node dist/app.js",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix",
        "test": "vitest run",
        "test:ui": "vitest --ui --coverage",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest --watch",
        "generate-spec": "cross-env NODE_ENV=build tsx src/generate-openapi-spec.ts",
        "db:typegen": "pnpm kysely-codegen",
        "db:migrate-latest": "pnpm kysely migrate:latest",
        "db:migrate-up": "pnpm kysely migrate:up",
        "db:migrate-down": "pnpm kysely migrate:down",
        "db:migrate-list": "pnpm kysely migrate:list",
        "db:migrate-create": "pnpm kysely migrate:make",
        "db:seed-create": "pnpm kysely seed:make",
        "db:seed-run": "pnpm kysely seed:run",
        "db:insert-assets": "tsx src/database/scripts/insert-assets.ts",
        "db:drop-asset-prices": "tsx src/database/scripts/drop-asset-prices.ts"
    },
    "kysely-codegen": {
        "dialect": "postgres",
        "camelCase": true,
        "envFile": ".env",
        "outFile": "./src/database/types.ts",
        "runtimeEnums": false,
        "typeOnlyImports": true
    },
    "author": "Kishan Jethwa",
    "license": "ISC",
    "dependencies": {
        "@fastify/autoload": "^6.3.1",
        "@fastify/cors": "^10.1.0",
        "@fastify/formbody": "^8.0.2",
        "@fastify/helmet": "^13.0.2",
        "@fastify/jwt": "^9.1.0",
        "@fastify/request-context": "^6.2.1",
        "@fastify/sensible": "^6.0.4",
        "@fastify/swagger": "^9.6.1",
        "@fastify/type-provider-typebox": "^5.2.0",
        "@sinclair/typebox": "^0.33.22",
        "better-auth": "^1.4.9",
        "country-to-currency": "^2.0.2",
        "currency-codes": "^2.2.0",
        "dayjs": "^1.11.19",
        "dotenv": "^16.6.1",
        "fastify": "^5.6.2",
        "fastify-plugin": "^5.1.0",
        "i18n-iso-countries": "^7.14.0",
        "jose": "^6.1.3",
        "kysely": "^0.28.9",
        "nodemailer": "^7.0.12",
        "pg": "^8.16.3",
        "pino": "^9.14.0",
        "pino-loki": "^2.6.0",
        "tsx": "^4.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/cli-progress": "^3.11.6",
        "@types/nodemailer": "^7.0.4",
        "@types/pg": "^8.16.0",
        "@vitest/coverage-istanbul": "4.0.16",
        "@vitest/ui": "4.0.16",
        "cli-progress": "^3.12.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-promise": "^6.6.0",
        "globals": "^15.15.0",
        "kysely-codegen": "^0.19.0",
        "kysely-ctl": "^0.19.0",
        "p-limit": "^7.2.0",
        "pino-pretty": "^11.3.0",
        "prettier": "3.3.3",
        "prettier-eslint": "^16.4.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.50.1",
        "vitest": "4.0.16"
    }
}
