{
    "name": "@stratify/stratify-api",
    "version": "0.3.0",
    "description": "",
    "type": "module",
    "main": "dist/app.js",
    "private": true,
    "files": [
        "dist",
        "docs"
    ],
    "scripts": {
        "prebuild": "pnpm generate-spec && pnpm data-api-typegen",
        "build": "tsc",
        "predev": "pnpm generate-spec && pnpm data-api-typegen",
        "dev": "tsx --watch src/app.ts",
        "prod": "node dist/app.js",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix",
        "test": "pnpm test-db:start && pnpm dotenv -e .env.test vitest run && pnpm test-db:stop",
        "test:ui": "pnpm test-db:start && pnpm dotenv -e .env.test vitest --ui --coverage && pnpm test-db:stop",
        "test:coverage": "pnpm test-db:start && pnpm dotenv -e .env.test vitest run --coverage && pnpm test-db:stop",
        "test:watch": "pnpm test-db:start && pnpm dotenv -e .env.test vitest --watch && pnpm test-db:stop",
        "generate-spec": "cross-env NODE_ENV=build tsx src/generate-openapi-spec.ts",
        "data-api-typegen": "openapi-typescript ../stratify-data-api/docs/openapi.json -o ./src/lib/api/stratify-data-api.d.ts",
        "db:typegen": "pnpm kysely-codegen",
        "db:migrate-latest": "pnpm kysely migrate:latest",
        "db:migrate-up": "pnpm kysely migrate:up",
        "db:migrate-down": "pnpm kysely migrate:down",
        "db:migrate-list": "pnpm kysely migrate:list",
        "db:migrate-create": "pnpm kysely migrate:make",
        "db:seed-create": "pnpm kysely seed:make",
        "db:seed-run": "pnpm kysely seed:run",
        "db:insert-assets": "tsx src/database/scripts/insert-assets.ts && tsx src/process-asset-names/update-asset-details.ts",
        "db:update-asset-details": "tsx src/process-asset-names/update-asset-details.ts",
        "db:drop-assets": "tsx src/database/scripts/drop-assets.ts",
        "test-db:start": "docker compose -f ./docker-compose.yml up -d && pnpm dotenv -e .env.test tsx src/utils/test-db-healthcheck.ts && pnpm test-db:prepare",
        "test-db:prepare": "pnpm dotenv -e .env.test pnpm kysely migrate:latest && pnpm dotenv -e .env.test pnpm db:seed-run",
        "test-db:stop": "docker compose -f ./docker-compose.yml down --volumes"
    },
    "kysely-codegen": {
        "dialect": "postgres",
        "camelCase": true,
        "envFile": ".env",
        "outFile": "./src/database/types.ts",
        "runtimeEnums": false,
        "typeOnlyImports": true
    },
    "author": "Kishan Jethwa",
    "license": "ISC",
    "dependencies": {
        "@fastify/autoload": "^6.3.1",
        "@fastify/cors": "^10.1.0",
        "@fastify/formbody": "^8.0.2",
        "@fastify/helmet": "^13.0.2",
        "@fastify/jwt": "^9.1.0",
        "@fastify/request-context": "^6.2.1",
        "@fastify/sensible": "^6.0.4",
        "@fastify/swagger": "^9.6.1",
        "@fastify/type-provider-typebox": "^5.2.0",
        "@sinclair/typebox": "^0.33.22",
        "better-auth": "^1.4.9",
        "country-to-currency": "^2.0.2",
        "currency-codes": "^2.2.0",
        "dayjs": "^1.11.19",
        "dotenv": "^16.6.1",
        "easy-currencies": "^1.8.3",
        "fastify": "^5.6.2",
        "fastify-plugin": "^5.1.0",
        "i18n-iso-countries": "^7.14.0",
        "jose": "^6.1.3",
        "ky": "^1.14.2",
        "kysely": "^0.28.9",
        "nodemailer": "^7.0.12",
        "openapi-fetch": "^0.15.0",
        "pg": "^8.16.3",
        "pino": "^9.14.0",
        "pino-loki": "^2.6.0",
        "tsx": "^4.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/cli-progress": "^3.11.6",
        "@types/nodemailer": "^7.0.4",
        "@types/pg": "^8.16.0",
        "@vitest/coverage-istanbul": "4.0.17",
        "@vitest/ui": "4.0.17",
        "cli-progress": "^3.12.0",
        "cross-env": "^7.0.3",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-promise": "^6.6.0",
        "globals": "^15.15.0",
        "kysely-codegen": "^0.19.0",
        "kysely-ctl": "^0.19.0",
        "openapi-typescript": "^7.10.1",
        "p-limit": "^7.2.0",
        "pino-pretty": "^11.3.0",
        "prettier": "3.3.3",
        "prettier-eslint": "^16.4.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.50.1",
        "vitest": "4.0.17",
        "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
    }
}
